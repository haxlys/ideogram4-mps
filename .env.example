# ── Magic Prompt (LLM) ───────────────────────────────────────────
# Hosted OpenAI-compatible provider
IDEOGRAM4_MAGIC_PROMPT_API_KEY=sk_xxxxx
# IDEOGRAM4_MAGIC_PROMPT_PROVIDER=openai_compatible
# IDEOGRAM4_MAGIC_PROMPT_MODEL=your-model
# IDEOGRAM4_MAGIC_PROMPT_BASE_URL=https://api.example.com/v1
# IDEOGRAM4_MAGIC_PROMPT_PROMPT_PROFILE=ideogram_official
# IDEOGRAM4_MAGIC_PROMPT_RESPONSE_FORMAT=off
# IDEOGRAM4_MAGIC_PROMPT_TOKEN_PARAM=max_tokens
# IDEOGRAM4_MAGIC_PROMPT_TIMEOUT=120
# IDEOGRAM4_MAGIC_PROMPT_MAX_TOKENS=16384
# IDEOGRAM4_MAGIC_PROMPT_TEMPERATURE=1.0

# Local managed llama.cpp example
# IDEOGRAM4_MAGIC_PROMPT_PROVIDER=llama_cpp
# IDEOGRAM4_MAGIC_PROMPT_PROMPT_PROFILE=compact_json
# IDEOGRAM4_MAGIC_PROMPT_BASE_URL=http://127.0.0.1:18082/v1
# IDEOGRAM4_MAGIC_PROMPT_MODEL=local-gemma4-12b
# IDEOGRAM4_MAGIC_PROMPT_API_KEY=local
# IDEOGRAM4_MAGIC_PROMPT_MANAGED_LLAMA=1
# IDEOGRAM4_MAGIC_PROMPT_LOCAL_LLAMA_PORT=18082
# IDEOGRAM4_MAGIC_PROMPT_LOCAL_LLAMA_MODEL=/path/to/model.gguf
# IDEOGRAM4_MAGIC_PROMPT_LOCAL_LLAMA_MMPROJ=/path/to/mmproj.gguf
# IDEOGRAM4_MAGIC_PROMPT_LOCAL_LLAMA_CTX=8192
# IDEOGRAM4_MAGIC_PROMPT_TEMPERATURE=0.1

# ── Server ────────────────────────────────────────────────────────
# IDEOGRAM4_SERVER_HOST=0.0.0.0
# IDEOGRAM4_SERVER_PORT=8000
# IDEOGRAM4_WEBUI_PORT=5173
# IDEOGRAM4_SERVER_LOG_LEVEL=info
# IDEOGRAM4_CORS_ORIGINS=*

# ── Model ─────────────────────────────────────────────────────────
# IDEOGRAM4_MODEL_REPO=ideogram-ai/ideogram-4-fp8

# ── Generation defaults ───────────────────────────────────────────
# IDEOGRAM4_DEFAULT_PRESET=V4_QUALITY_48
# IDEOGRAM4_DEFAULT_FORMAT=webp
# IDEOGRAM4_DEFAULT_SEED=20260608
# IDEOGRAM4_IMAGE_QUALITY_WEBP=90
# IDEOGRAM4_IMAGE_QUALITY_JPEG=95

# ── Paths ─────────────────────────────────────────────────────────
# IDEOGRAM4_LOG_DIR=logs
# IDEOGRAM4_DB_PATH=server/data/ideogram4.db
# IDEOGRAM4_OUTPUT_DIR=server/output
# IDEOGRAM4_LORA_DIR=models/loras

# ── LoRA ──────────────────────────────────────────────────────────
# IDEOGRAM4_LORA_STRENGTH=0.6

# ── Warmup ────────────────────────────────────────────────────────
# IDEOGRAM4_WARMUP_SIZE=64
# IDEOGRAM4_WARMUP_STEPS=2

# ── DB ────────────────────────────────────────────────────────────
# IDEOGRAM4_DB_QUERY_LIMIT=50
